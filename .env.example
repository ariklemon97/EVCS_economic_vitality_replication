# =============================================================================
# API Keys Configuration — Copy to .env and fill in your keys
# =============================================================================

# Dewey Data API Keys (https://deweydata.io)
DEWEY_FOOT_TRAFFIC_KEY=your_dewey_foot_traffic_key
DEWEY_GLOBAL_PLACES_KEY=your_dewey_global_places_key
DEWEY_SPEND_PATTERNS_KEY=your_dewey_spend_patterns_key

# Dewey Data API URLs (base endpoints)
DEWEY_FOOT_TRAFFIC_URL=https://api.deweydata.io/api/v1/external/data/your_foot_traffic_project
DEWEY_GLOBAL_PLACES_URL=https://api.deweydata.io/api/v1/external/data/your_global_places_project
DEWEY_SPEND_PATTERNS_URL=https://api.deweydata.io/api/v1/external/data/your_spend_patterns_project

# NREL Alternative Fuel Stations API
# Sign up for a free key at: https://developer.nrel.gov/signup/
NREL_API_KEY=DEMO_KEY
